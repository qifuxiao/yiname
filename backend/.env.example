# Supabase Database URL
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.xxx.supabase.co:5432/postgres

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# AI Service (Moligan / 魔力方舟)
MOLIGAN_URL=https://ai.gitee.com/v1/chat/completions
MOLIGAN_API_KEY=your-api-key-here
MOLIGAN_MODEL=Qwen3.5-27B

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
